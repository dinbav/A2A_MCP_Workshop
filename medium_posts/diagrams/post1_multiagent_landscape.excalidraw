      "type": "text",
      "x": 270,
      "y": 215,
      "width": 120,
      "height": 30,
      "text": "🧠 Orchestrator\n(A2A Agent)",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent"
    },
    {
      "id": "arrow-orch-agent1",
