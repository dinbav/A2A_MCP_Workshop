    },
    {
      "id": "legend-mcp",
      "type": "text",
      "x": 40,
      "y": 475,
      "width": 200,
      "height": 20,
      "text": "⤳  MCP (tool calls)",
      "fontSize": 13,
      "fontFamily": 1,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent"
    },
    {
      "id": "title",
      "type": "text",
      "x": 40,
      "y": 40,
      "width": 450,
      "height": 40,
      "text": "The Multi-Agent Landscape: A2A + MCP",
      "fontSize": 22,
      "fontFamily": 1,
      "fontStyle": "bold",
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent"
    },
    {
      "id": "subtitle",
      "type": "text",
      "x": 40,
      "y": 85,
      "width": 500,
      "height": 20,
      "text": "User → Orchestrator (A2A) → Remote Agents → MCP Server (tools)",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#666",
      "backgroundColor": "transparent"
    }
  ],
  "appState": {
    "viewBackgroundColor": "#ffffff",
    "gridSize": 20
  }
}
